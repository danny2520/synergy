@page
@model SynergyDotCom.Pages.Shared.Admin.Poems.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].Theme)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].Excerpt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].Body)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].ImageUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].PublishedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poem[0].Author)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Poem) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Theme)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Excerpt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Body)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ImageUrl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PublishedDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Author)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
