@page
@model SynergyDotCom.Pages.Admin.News.DetailsModel
@{
    ViewData["Title"] = Model.PoliticsPost.Headline;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<style>
    /* MODERN NEWS THEME */
    :root {
        --news-accent: #009688; /* Teal/Green - Professional & Calm */
        --news-dark: #111111;
        --news-gray: #555555;
        --news-bg: #ffffff;
    }

    body {
        background-color: #f4f6f8; /* Soft gray background for the whole page */
        font-family: 'Inter', sans-serif;
        color: var(--news-dark);
    }

    .article-container {
        max-width: 900px;
        margin: 40px auto;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05); /* Subtle lift */
        padding: 0;
        border-radius: 8px;
        overflow: hidden;
    }

    /* HEADER SECTION */
    .article-header {
        padding: 60px 50px 40px;
        text-align: center;
        border-bottom: 1px solid #eaeaea;
    }

    .source-badge {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--news-accent);
        border: 1px solid var(--news-accent);
        padding: 6px 12px;
        border-radius: 50px;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        .source-badge:hover {
            background-color: var(--news-accent);
            color: white;
        }

    .headline {
        font-family: 'Playfair Display', serif;
        font-size: 3.2rem;
        font-weight: 700;
        line-height: 1.15;
        color: var(--news-dark);
        margin-bottom: 20px;
    }

    .meta-data {
        font-size: 0.9rem;
        color: #888;
        font-weight: 500;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
    }

    .breaking-indicator {
        color: #d90429;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 5px;
        animation: pulse 2s infinite;
    }

    /* IMAGE SECTION */
    .hero-image-wrapper {
        width: 100%;
        height: 500px;
        overflow: hidden;
        position: relative;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* CONTENT BODY */
    .article-content-wrapper {
        padding: 60px 50px;
    }

    .summary-box {
        background-color: #f8f9fa;
        border-left: 4px solid var(--news-accent);
        padding: 25px;
        margin-bottom: 40px;
        border-radius: 0 4px 4px 0;
    }

    .summary-text {
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        font-size: 1.1rem;
        color: var(--news-gray);
        line-height: 1.6;
        font-style: normal; /* Ensuring normal text */
    }

    .article-text {
        font-family: 'Inter', sans-serif;
        font-size: 1.125rem; /* 18px */
        line-height: 1.85;
        color: #2c2c2c; /* High contrast dark gray, not pure black */
        font-style: normal; /* STRICTLY NORMAL */
        font-weight: 400;
    }

        /* Paragraph spacing */
        .article-text p {
            margin-bottom: 1.5em;
        }

        /* Dropcap for the first letter */
        .article-text::first-letter {
            float: left;
            font-family: 'Playfair Display', serif;
            font-size: 4.5rem;
            line-height: 0.8;
            padding-top: 4px;
            padding-right: 12px;
            color: var(--news-dark);
            font-weight: 700;
        }

    /* FOOTER */
    .article-footer {
        padding: 30px 50px;
        background-color: #fdfdfd;
        border-top: 1px solid #eaeaea;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        text-decoration: none;
        color: var(--news-dark);
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }

        .btn-back:hover {
            color: var(--news-accent);
            transform: translateX(-5px);
        }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }

    /* Mobile Responsiveness */
    @@media (max-width: 768px) {
        .article-header, .article-content-wrapper, .article-footer {
            padding: 30px 20px;
        }

        .headline {
            font-size: 2.2rem;
        }

        .hero-image-wrapper {
            height: 300px;
        }
    }
</style>

<div class="article-container">

    <div class="article-header">
        <a href="#" class="source-badge">@Html.DisplayFor(model => model.PoliticsPost.Source)</a>

        <h1 class="headline">@Html.DisplayFor(model => model.PoliticsPost.Headline)</h1>

        <div class="meta-data">
            <span><i class="bi bi-calendar3"></i> @Model.PoliticsPost.Date.ToString("MMM dd, yyyy")</span>
            <span style="color: #ddd;">|</span>
            <span><i class="bi bi-clock"></i> @Model.PoliticsPost.Date.ToString("h:mm tt")</span>

            @if (Model.PoliticsPost.IsBreakingNews)
            {
                <span style="color: #ddd;">|</span>
                <span class="breaking-indicator"><i class="bi bi-record-circle-fill"></i> LIVE UPDATE</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.PoliticsPost.ImageUrl))
    {
        <div class="hero-image-wrapper">
            <img src="@Model.PoliticsPost.ImageUrl" class="hero-image" alt="News Image">
        </div>
    }

    <div class="article-content-wrapper">

        @if (!string.IsNullOrEmpty(Model.PoliticsPost.Summary))
        {
            <div class="summary-box">
                <h6 class="text-uppercase fw-bold mb-2" style="color: var(--news-accent); font-size: 0.75rem; letter-spacing: 1px;">Key Points</h6>
                <div class="summary-text">
                    @Html.DisplayFor(model => model.PoliticsPost.Summary)
                </div>
            </div>
        }

        <div class="article-text">
            @if (!string.IsNullOrEmpty(Model.PoliticsPost.FullStory))
            {
                @Html.Raw(Model.PoliticsPost.FullStory.Replace("\n", "<br><br>"))
            }
            else
            {
                @Html.Raw(Model.PoliticsPost.Body?.Replace("\n", "<br><br>"))
            }
        </div>

    </div>

    <div class="article-footer">
        <a asp-page="/Politics" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to Senate Floor
        </a>
        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-printer me-2"></i> Print Article
        </button>
    </div>

</div>