@page
@model SynergyDotCom.Pages.Shared.Admin.News.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].Headline)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].Summary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].FullStory)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].Source)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].ImageUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].IsBreakingNews)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PoliticsPost[0].Date)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.PoliticsPost) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Headline)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Summary)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FullStory)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Source)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ImageUrl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsBreakingNews)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
