<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SYNERGY.COM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Merriweather:ital,wght@0,300;0,700;1,400&display=swap" rel="stylesheet">

    <style>
        /* GLOBAL THEME */
        :root {
            --synergy-dark: #0f172a;
            --synergy-cyan: #00d2ff;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, .serif-font {
            font-family: 'Merriweather', serif;
        }

        /* CUSTOM NAVBAR */
        .navbar-custom {
            background-color: var(--synergy-dark);
            border-bottom: 3px solid var(--synergy-cyan);
            padding: 1rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .navbar-brand span {
            font-family: 'Inter', sans-serif;
            letter-spacing: 1px;
        }

        .nav-link {
            color: rgba(255,255,255,0.7) !important;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            transition: all 0.3s;
            margin: 0 10px;
        }

            .nav-link:hover, .nav-link.active {
                color: var(--synergy-cyan) !important;
                transform: translateY(-2px);
            }

        /* CONNECT BUTTON */
        .btn-nav-connect {
            border: 1px solid var(--synergy-cyan);
            color: var(--synergy-cyan);
            border-radius: 0;
            padding: 5px 20px;
            font-weight: bold;
            transition: 0.3s;
        }

            .btn-nav-connect:hover {
                background: var(--synergy-cyan);
                color: var(--synergy-dark);
            }

        /* MEGA FOOTER */
        footer {
            background-color: var(--synergy-dark);
            border-top: 5px solid var(--synergy-cyan);
            color: white;
            padding-top: 4rem;
            margin-top: auto; /* Pushes footer to bottom */
        }

        .footer-heading {
            color: var(--synergy-cyan);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        footer a {
            transition: 0.2s;
        }

            footer a:hover {
                color: var(--synergy-cyan) !important;
                padding-left: 5px;
            }

        .input-group-dark input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
        }

            .input-group-dark input:focus {
                background: rgba(255,255,255,0.2);
                color: white;
                border-color: var(--synergy-cyan);
                box-shadow: none;
            }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
                         stroke="#00d2ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="filter: drop-shadow(0 0 5px #00d2ff);">
                        <circle cx="18" cy="5" r="3"></circle>
                        <circle cx="6" cy="12" r="3"></circle>
                        <circle cx="18" cy="19" r="3"></circle>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                    </svg>
                    <span class="fw-bold text-white fs-4">SYNERGY<span style="color: #00d2ff;">.COM</span></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Law">Law</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Politics">Politics</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Anthology">Anthology</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Culinary">Culinary</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/About">About</a></li>
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-nav-connect" asp-page="/Contact">CONNECT</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container pb-5">
            <div class="row gy-5">

                <div class="col-lg-4 col-md-12">
                    <h5 class="fw-bold text-white mb-3 d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d2ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="18" cy="5" r="3"></circle>
                            <circle cx="6" cy="12" r="3"></circle>
                            <circle cx="18" cy="19" r="3"></circle>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                        </svg>
                        SYNERGY<span class="text-info">.COM</span>
                    </h5>
                    <p class="text-white-50 small mb-4" style="max-width: 300px;">
                        Bridging the gap between the gavel, the ballot box, and the poet's pen. The future of discourse is here.
                    </p>

                    <div class="d-flex gap-3">
                        <a href="https://wa.me/2347035559139" target="_blank" class="text-white" title="WhatsApp">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                        </a>
                        <a href="https://www.instagram.com/obatayoade?igsh=cDBjZWFvNTdtMjRz" target="_blank" class="text-white" title="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                        </a>
                        <a href="https://t.me/obatayoade" target="_blank" class="text-white" title="Telegram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0088cc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                        </a>
                    </div>
                </div>

                <div class="col-lg-2 col-6">
                    <h6 class="footer-heading">Explore</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-page="/Law" class="text-decoration-none text-white-50">Legal Insights</a></li>
                        <li class="mb-2"><a asp-page="/Politics" class="text-decoration-none text-white-50">Political View</a></li>
                        <li class="mb-2"><a asp-page="/Anthology" class="text-decoration-none text-white-50">Anthology</a></li>
                        <li class="mb-2"><a asp-page="/About" class="text-decoration-none text-white-50">About Curator</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-6">
                    <h6 class="footer-heading">Legal</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-page="/Privacy" class="text-decoration-none text-white-50">Privacy Policy</a></li>
                        <li class="mb-2"><a asp-page="/Privacy" class="text-decoration-none text-white-50">Terms of Use</a></li>
                        <li class="mb-2"><a asp-page="/Contact" class="text-decoration-none text-white-50">Submit Work</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12">
                    <h6 class="footer-heading">Join the Network</h6>
                    <p class="small text-white-50">Get our weekly digest on Law and Ogun State politics.</p>
                    <div class="input-group input-group-dark mb-3">
                        <input type="text" class="form-control" placeholder="Email Address">
                        <button class="btn btn-info fw-bold" type="button">Subscribe</button>
                    </div>
                </div>

            </div>
        </div>

        <div class="py-3 text-center border-top border-secondary">
            <p class="small text-white-50 mb-0">&copy; 2025 Synergy Inc. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            once: true
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>